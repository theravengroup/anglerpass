# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
STRIPE_WEBHOOK_SIGNING_SECRET_CONNECT=whsec_your-connect-webhook-secret
STRIPE_WEBHOOK_SIGNING_SECRET_VERIFICATION=whsec_your-verification-webhook-secret

# Mapbox (for property map)
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-public-token

# Sentry (error monitoring)
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn

# Cloudflare Turnstile (CAPTCHA)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Resend (transactional email)
RESEND_API_KEY=re_your-resend-api-key

# Checkr (guide background checks)
CHECKR_API_KEY=your-checkr-api-key
CHECKR_WEBHOOK_SECRET=your-checkr-webhook-secret

# Twilio (SMS notifications)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890

# Vercel cron job auth
CRON_SECRET=your-cron-secret

# Site
NEXT_PUBLIC_SITE_URL=https://anglerpass.com

# Unsubscribe token signing (falls back to SUPABASE_SERVICE_ROLE_KEY if unset)
UNSUBSCRIBE_SECRET=your-unsubscribe-hmac-secret
